#!/usr/bin/env python3
import os, sys, subprocess, tempfile, threading, urllib.parse, webbrowser
import tkinter as tk
from tkinter import ttk, messagebox, filedialog

try:
    from PIL import Image, ImageTk
except ImportError: pass

def check_os_compatibility():
    try:
        with open("/etc/os-release") as f:
            c = f.read().lower()
            if "sid" in c or "unstable" in c:
                t = tk.Tk(); t.withdraw()
                messagebox.showerror("Unsupported OS", "Debos is for Debian Stable/Testing & LTS.")
                sys.exit(1)
    except: pass

check_os_compatibility()

def check_system_health():
    try:
        res = subprocess.run(['dpkg', '--audit'], capture_output=True, text=True)
        if res.stdout.strip(): subprocess.run(['notify-send', '-u', 'critical', '-i', '/usr/share/pixmaps/debos-toolbox.png', 'Debos - Toolbox', 'Broken packages detected. Open Debos to fix.'])
    except: pass

if "--startup" in sys.argv: check_system_health(); sys.exit(0)

