            self.i3 = ImageTk.PhotoImage(Image.open("/usr/share/pixmaps/debos-linux.png").resize((80, 80)))
            tk.Button(img_f, image=self.i3, bd=0, command=lambda: webbrowser.open("https://www.linuxfoundation.org/")).pack(side="left", padx=10)
            self.i4 = ImageTk.PhotoImage(Image.open("/usr/share/pixmaps/debos-github.png").resize((80, 80)))
            tk.Button(img_f, image=self.i4, bd=0, command=lambda: webbrowser.open("https://github.com/hugomonizdorego")).pack(side="left", padx=10)
        except: pass

        self.autostart_file = os.path.expanduser("~/.config/autostart/debos-toolbox.desktop")
        self.autostart_var = tk.BooleanVar(value=os.path.exists(self.autostart_file))
        ttk.Checkbutton(sa, text="Run at System Startup (Background Health Monitor)", variable=self.autostart_var, command=self.toggle_autostart).pack(anchor="w", pady=(15, 10))
        
        ff = tk.Frame(sa, bg=self.CONTENT_BG); ff.pack(anchor="w", fill="x", pady=20)
        tk.Label(ff, text="Send Feedback & Suggestions", font=('Segoe UI', 12, 'bold'), bg=self.CONTENT_BG).grid(row=0, column=0, columnspan=2, sticky="w", pady=5)
        tk.Label(ff, text="Name:", bg=self.CONTENT_BG).grid(row=1, column=0, sticky="w", pady=2)
        self.fb_name = tk.Entry(ff, width=40); self.fb_name.grid(row=1, column=1, pady=2, padx=5)
        tk.Label(ff, text="Email:", bg=self.CONTENT_BG).grid(row=2, column=0, sticky="w", pady=2)
        self.fb_email = tk.Entry(ff, width=40); self.fb_email.grid(row=2, column=1, pady=2, padx=5)
        
        distro = "Unknown"
        try:
            with open("/etc/os-release") as file:
                for line in file:
                    if line.startswith("PRETTY_NAME="): distro = line.split("=")[1].strip().strip('"')
        except: pass
        tk.Label(ff, text="OS/Distro:", bg=self.CONTENT_BG).grid(row=3, column=0, sticky="w", pady=2)
        self.fb_distro = tk.Entry(ff, width=40); self.fb_distro.insert(0, distro); self.fb_distro.grid(row=3, column=1, pady=2, padx=5)
        tk.Label(ff, text="Message:", bg=self.CONTENT_BG).grid(row=4, column=0, sticky="nw", pady=2)
        self.fb_msg = tk.Text(ff, height=4, width=40, font=('Segoe UI', 10), bd=0, highlightbackground="#CCC", highlightcolor="#3498DB", highlightthickness=1)
        self.fb_msg.grid(row=4, column=1, pady=2, padx=5)
        ttk.Button(ff, text="Send via Mail Client", style='Action.TButton', command=self.send_feedback).grid(row=5, column=1, sticky="w", pady=10)

    def toggle_autostart(self):
        if self.autostart_var.get():
            os.makedirs(os.path.dirname(self.autostart_file), exist_ok=True)
            with open(self.autostart_file, "w") as f:
                f.write("[Desktop Entry]\nType=Application\nExec=/usr/bin/debos-toolbox --startup\nHidden=false\nNoDisplay=false\nX-GNOME-Autostart-enabled=true\nName=Debos System Monitor\nComment=Checks system health\nIcon=/usr/share/pixmaps/debos-toolbox.png\n")
        else:
            if os.path.exists(self.autostart_file): os.remove(self.autostart_file)

    def send_feedback(self):
        name = self.fb_name.get().strip()
        msg = self.fb_msg.get("1.0", tk.END).strip()
        if not msg or not name: return messagebox.showwarning("Warning", "Name and Message are required.")
        body = urllib.parse.quote(f"Name: {name}\nEmail: {self.fb_email.get().strip()}\nOS: {self.fb_distro.get().strip()}\n\nFeedback:\n{msg}")
        webbrowser.open(f"mailto:hugomonizdorego@gmail.com?subject=Feedback for Debos-Toolbox&body={body}")

