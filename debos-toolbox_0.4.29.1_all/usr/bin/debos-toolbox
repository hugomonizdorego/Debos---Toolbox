class DebosToolboxApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Debos - Toolbox v0.4.29.1")
        self.root.geometry("1150x800")
        self.SIDEBAR_BG, self.SIDEBAR_FG, self.SIDEBAR_HOVER, self.SIDEBAR_ACTIVE, self.CONTENT_BG = "#1A252F", "#ECF0F1", "#2C3E50", "#3498DB", "#FFFFFF"
        self.root.configure(bg=self.CONTENT_BG)
        
        style = ttk.Style()
        if 'clam' in style.theme_names(): style.theme_use('clam')
        style.configure('TFrame', background=self.CONTENT_BG)
        style.configure('TCheckbutton', background=self.CONTENT_BG, font=('Segoe UI', 10))
        style.configure('App.TCheckbutton', background=self.CONTENT_BG, font=('Segoe UI', 11, 'bold'), foreground="#2C3E50")
        style.configure('TRadiobutton', background=self.CONTENT_BG, font=('Segoe UI', 10, 'bold'), foreground="#2C3E50")
        style.configure('TLabel', background=self.CONTENT_BG, font=('Segoe UI', 10))
        style.configure('Header.TLabel', background=self.CONTENT_BG, font=('Segoe UI', 18, 'bold'), foreground='#2C3E50')
        style.configure('Action.TButton', font=('Segoe UI', 10, 'bold'), padding=10, background='#3498DB', foreground='white')
        style.configure('Danger.TButton', font=('Segoe UI', 10, 'bold'), padding=10, background='#E74C3C', foreground='white')

        self.current_lang = tk.StringVar(value="English")
        tf = tk.Frame(self.root, bg="#ECF0F1", height=70); tf.pack(side="top", fill="x")
        tk.Label(tf, text="Debos - Toolbox", bg="#ECF0F1", font=('Segoe UI', 20, 'bold'), fg="#2C3E50").pack(side="left", padx=25, pady=10)
        self.lang_menu = ttk.Combobox(tf, textvariable=self.current_lang, values=list(LANGUAGES.keys()), state="readonly", width=15)
        self.lang_menu.pack(side='right', padx=25, pady=15); self.lang_menu.bind("<<ComboboxSelected>>", self.update_texts)

        mc = tk.Frame(self.root, bg=self.CONTENT_BG); mc.pack(fill="both", expand=True)
        self.sidebar = tk.Frame(mc, bg=self.SIDEBAR_BG, width=250); self.sidebar.pack(side="left", fill="y"); self.sidebar.pack_propagate(False)
        self.content_area = tk.Frame(mc, bg=self.CONTENT_BG); self.content_area.pack(side="right", fill="both", expand=True, padx=30, pady=30)

        self.pages, self.nav_buttons = {}, {}
        self.create_pages(); self.create_sidebar_buttons(); self.show_page("clean")

    def create_sidebar_buttons(self):
        btns = [("clean", "Clean System"), ("repo", "Fix Repo & GPG"), ("kernels", "Install Kernels"), ("manual", "Uninstall Kernel"), ("install_sw", "Install Software"), ("uninstall_sw", "Uninstall Software"), ("drivers", "Drivers & Hardware"), ("network", "Network Config"), ("customizer", "Customizer"), ("sources", "Edit Sources"), ("about", "About & Feedback"), ("license", "License")]
        for key, txt in btns:
            b = tk.Button(self.sidebar, text=f"  {txt}", bg=self.SIDEBAR_BG, fg=self.SIDEBAR_FG, font=('Segoe UI', 11), bd=0, anchor="w", padx=20, pady=12, activebackground=self.SIDEBAR_HOVER, command=lambda k=key: self.show_page(k))
            b.pack(fill="x"); self.nav_buttons[key] = b

    def show_page(self, page_key):
        for k, b in self.nav_buttons.items(): b.config(bg=self.SIDEBAR_ACTIVE if k == page_key else self.SIDEBAR_BG)
        for f in self.pages.values(): f.pack_forget()
        self.pages[page_key].pack(fill="both", expand=True)
        if page_key == "manual": self.refresh_kernel_list()
        elif page_key == "uninstall_sw": self.refresh_software_list()
        elif page_key == "network": self.refresh_interfaces()

    def update_texts(self, e=None):
        lang = LANGUAGES.get(self.current_lang.get(), LANGUAGES["English"])
        for k, b in self.nav_buttons.items(): b.config(text=f"  {lang.get(k, k)}")

    def create_scroll_area(self, parent):
        c = tk.Canvas(parent, bg=self.CONTENT_BG, highlightthickness=0); s = ttk.Scrollbar(parent, orient="vertical", command=c.yview)
        f = tk.Frame(c, bg=self.CONTENT_BG)
        f.bind("<Configure>", lambda e: c.configure(scrollregion=c.bbox("all")))
        c.create_window((0, 0), window=f, anchor="nw"); c.configure(yscrollcommand=s.set)
        c.pack(side="left", fill="both", expand=True); s.pack(side="right", fill="y")
        c.bind('<Enter>', lambda e: c.bind_all("<Button-4>", lambda e: c.yview_scroll(-1, "units")) or c.bind_all("<Button-5>", lambda e: c.yview_scroll(1, "units")))
        c.bind('<Leave>', lambda e: c.unbind_all("<Button-4>") or c.unbind_all("<Button-5>"))
        return f

    def execute_in_terminal(self, cmds, pause=True):
        scr = "#!/bin/bash\ncd /tmp || exit\n" + "\n".join(cmds)
        scr += "\necho -e '\\n\\e[1;32m[+] Process Finished!\\e[0m'; read -p 'Press Enter...'\n" if pause else "\nsleep 2\n"
        fd, path = tempfile.mkstemp(suffix=".sh")
        os.write(fd, scr.encode('utf-8')); os.close(fd); os.chmod(path, 0o755)
        subprocess.Popen(['x-terminal-emulator', '-e', 'sudo', 'bash', path])

    def create_pages(self):
        self.setup_clean_page(); self.setup_repo_page(); self.setup_kernel_page(); self.setup_manual_page()
        self.setup_install_sw_page(); self.setup_uninstall_sw_page(); self.setup_drivers_page()
        self.setup_network_page(); self.setup_customizer_page(); self.setup_sources_page()
        self.setup_about_page(); self.setup_license_page()

    def setup_clean_page(self):
        f = ttk.Frame(self.content_area); self.pages["clean"] = f
        ttk.Label(f, text="System Cleaning", style='Header.TLabel').pack(anchor="w", pady=(0, 20))
        self.cl_vars = {k: tk.BooleanVar(value=True) for k in ["old_kernels", "update_grub", "apt_cache", "rc_configs", "flatpak"]}
        self.cl_vars.update({"empty_folders": tk.BooleanVar(value=False), "duplicates": tk.BooleanVar(value=False)})
        opts = [("old_kernels", "Remove Old Kernels"), ("update_grub", "Update GRUB"), ("apt_cache", "Remove Cache"), ("rc_configs", "Remove Residual Configs"), ("flatpak", "Remove Unused Flatpak"), ("empty_folders", "Remove Empty Folders (/tmp)"), ("duplicates", "Remove Duplicates (/tmp)")]
        sa = self.create_scroll_area(f)
        for k, t in opts: ttk.Checkbutton(sa, text=t, variable=self.cl_vars[k]).pack(anchor="w", pady=6, padx=10)
        ttk.Button(f, text="Execute Cleaning", style='Action.TButton', command=self.run_cleaning).pack(pady=10, anchor="w")

    def run_cleaning(self):
        cmds = ["cd /tmp || exit"]
        if self.cl_vars["old_kernels"].get(): cmds.append("apt-get autoremove --purge -y")
        if self.cl_vars["update_grub"].get(): cmds.append("update-grub")
        if self.cl_vars["apt_cache"].get(): cmds.extend(["apt-get clean -y", "apt-get autoclean -y", "journalctl --vacuum-time=3d"])
        if self.cl_vars["rc_configs"].get(): cmds.append("dpkg -l | grep '^rc' | awk '{print $2}' | xargs -r dpkg --purge")
        if self.cl_vars["flatpak"].get(): cmds.append("flatpak uninstall --unused -y")
        if self.cl_vars["empty_folders"].get(): cmds.extend(["find ~/.cache /tmp -type d -empty -delete 2>/dev/null || true"])
        if self.cl_vars["duplicates"].get(): cmds.append("fdupes -rdN /tmp || true")
        if len(cmds) > 1: self.execute_in_terminal(cmds)

    def setup_repo_page(self):
        f = ttk.Frame(self.content_area); self.pages["repo"] = f
        ttk.Label(f, text="Fix Broken Repositories", style='Header.TLabel').pack(anchor="w", pady=(0, 20))
        ttk.Button(f, text="Fix APT & GPG Errors", style='Action.TButton', command=self.run_repo_fix).pack(pady=20, anchor="w")

    def run_repo_fix(self):
        cmds = [
            "echo -e '\\e[1;34m[*] Step 1: Global Repository Deduplication...\\e[0m'",
            "for f in /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do [ -f \"$f\" ] && awk '!seen[$0]++' \"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; done",
            "mkdir -p /etc/apt/apt.conf.d; echo 'Acquire::AllowWeakSignatures \"true\";' > /etc/apt/apt.conf.d/99-allow-weak-signatures",
            "echo -e '\\n\\e[1;34m[*] Step 2: Auto-fetching missing PUBKEYs from APT logs...\\e[0m'",
            "apt-get update 2> /tmp/apt-errors.log || true",
            "MISSING_KEYS=$(grep -oP 'NO_PUBKEY \\K[0-9A-F]+' /tmp/apt-errors.log | sort | uniq || true)",
            "for key in $MISSING_KEYS; do gpg --keyserver keyserver.ubuntu.com --recv-keys \"$key\" || true; gpg --export \"$key\" > /etc/apt/trusted.gpg.d/${key}.gpg || true; done",
            "dpkg --configure -a; apt-get --fix-broken install -y; apt-get update"
        ]
        self.execute_in_terminal(cmds)

    def setup_kernel_page(self):
        f = ttk.Frame(self.content_area); self.pages["kernels"] = f
        ttk.Label(f, text="Install Custom Kernels", style='Header.TLabel').pack(anchor="w", pady=10)
        sa = self.create_scroll_area(f); self.kernel_vars = {}
        for c, n, d in KERNELS_LIST:
            v = tk.BooleanVar(); self.kernel_vars[c] = v
            ttk.Checkbutton(sa, text=n, variable=v, style='App.TCheckbutton').pack(anchor="w", pady=(5, 0), padx=10)
            tk.Label(sa, text=d, bg=self.CONTENT_BG, fg="#7F8C8D", font=('Segoe UI', 9)).pack(anchor="w", padx=38, pady=(0, 5))
        ttk.Button(f, text="Install Selected Kernels", style='Action.TButton', command=self.install_kernel).pack(anchor="w", pady=10)

    def install_kernel(self):
        cmds = ["apt-get update"]
        sel = [c for c, v in self.kernel_vars.items() if v.get()]
        if not sel: return messagebox.showinfo("Info", "No kernel selected.")
        
        if "mainline_stable" in sel or "mainline_longterm" in sel:
            cmds.extend(["apt-get install -y build-essential libncurses-dev bison flex libssl-dev libelf-dev bc wget tar"])
            if "mainline_stable" in sel: cmds.extend(["VER=$(curl -s https://www.kernel.org/ | grep -A 1 'stable:' | grep -oP '(?<=<strong>).*?(?=</strong>)' | head -n1)", "wget -qO /tmp/linux-$VER.tar.xz https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-$VER.tar.xz", "tar -xf /tmp/linux-$VER.tar.xz -C /tmp && cd /tmp/linux-$VER", "cp /boot/config-$(uname -r) .config", "make olddefconfig && make -j$(nproc) && make modules_install && make install"])
            if "mainline_longterm" in sel: cmds.extend(["VER=$(curl -s https://www.kernel.org/ | grep -A 1 'longterm:' | grep -oP '(?<=<strong>).*?(?=</strong>)' | head -n1)", "wget -qO /tmp/linux-$VER.tar.xz https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-$VER.tar.xz", "tar -xf /tmp/linux-$VER.tar.xz -C /tmp && cd /tmp/linux-$VER", "cp /boot/config-$(uname -r) .config", "make olddefconfig && make -j$(nproc) && make modules_install && make install"])

        if any("xanmod" in c for c in sel): cmds.extend(["wget -qO - https://dl.xanmod.org/archive.key | gpg --dearmor -o /etc/apt/keyrings/xanmod-archive-keyring.gpg --yes", "echo 'deb [signed-by=/etc/apt/keyrings/xanmod-archive-keyring.gpg] http://deb.xanmod.org $(lsb_release -sc) main non-free' > /etc/apt/sources.list.d/xanmod.list", "apt-get update"])
        for c in sel:
            if "liquorix" in c: cmds.append("curl -s 'https://liquorix.net/install-liquorix.sh' | bash")
            elif "libre" in c: cmds.extend(["wget -O /tmp/freesh.deb https://linux-libre.fsfla.org/pub/linux-libre/freesh/pool/main/f/freesh-archive-keyring/freesh-archive-keyring_1.3_all.deb", "dpkg -i /tmp/freesh.deb", "apt-get update", "apt-get install -y linux-libre"])
            elif "mainline" not in c: cmds.append(f"apt-get install -y {c}")
        self.execute_in_terminal(cmds)

    def setup_manual_page(self):
        f = ttk.Frame(self.content_area); self.pages["manual"] = f
        ttk.Label(f, text="Uninstall Kernel", style='Header.TLabel').pack(anchor="w")
        self.lbl_curr = ttk.Label(f, text="Current: Loading...", font=('Segoe UI', 11, 'bold'), foreground="#27ae60"); self.lbl_curr.pack(anchor="w", pady=10)
        self.scroll_k_del = self.create_scroll_area(f); self.k_del_vars = {}
        bf = tk.Frame(f, bg=self.CONTENT_BG); bf.pack(anchor="w", pady=15)
        ttk.Button(bf, text="Refresh List", command=self.refresh_kernel_list).pack(side="left", padx=(0, 15))
        ttk.Button(bf, text="Remove Selected", style='Danger.TButton', command=self.remove_manual_kernel).pack(side="left")

    def refresh_kernel_list(self):
        try:
            curr = subprocess.run(['uname', '-r'], capture_output=True, text=True).stdout.strip(); self.lbl_curr.config(text=f"Currently running: {curr}")
            res = subprocess.run("dpkg-query -W -f='${Package}\\n' | grep -E '^linux-image'", shell=True, capture_output=True, text=True).stdout.strip().split('\n')
            safes = [k for k in res if k and curr not in k and "linux-image" in k]
            for w in self.scroll_k_del.winfo_children(): w.destroy()
            self.k_del_vars.clear()
            for k in safes:
                v = tk.BooleanVar(); self.k_del_vars[k] = v
                ttk.Checkbutton(self.scroll_k_del, text=f"🗑️ {k}", variable=v).pack(anchor="w", pady=5, padx=10)
        except: pass

    def remove_manual_kernel(self):
        to_rem = [k for k, v in self.k_del_vars.items() if v.get()]
        if to_rem and messagebox.askyesno("Confirm", f"Remove {len(to_rem)} kernels?"): self.execute_in_terminal([f"apt-get purge -y {' '.join(to_rem)}", "apt-get autoremove --purge -y", "update-grub"])

    def setup_install_sw_page(self):
        f = ttk.Frame(self.content_area); self.pages["install_sw"] = f
        ttk.Label(f, text="Install Software & Desktop Environments", style='Header.TLabel').pack(anchor="w", pady=(0, 10))
        nb = ttk.Notebook(f); nb.pack(fill='both', expand=True, pady=10)
        
        t1 = ttk.Frame(nb); t2 = ttk.Frame(nb); t3 = ttk.Frame(nb); t4 = ttk.Frame(nb)
        nb.add(t1, text="DEB Packages"); nb.add(t2, text="Flatpaks"); nb.add(t3, text="Desktop Envs"); nb.add(t4, text="Window Managers")
        
        self.deb_vars = {}; sd = self.create_scroll_area(t1)
        for c, i, n, d in DEB_SOFTWARE:
            v = tk.BooleanVar(); self.deb_vars[c] = v
            ttk.Checkbutton(sd, text=f"{i}  {n}", variable=v, style='App.TCheckbutton').pack(anchor="w", pady=(10, 0), padx=10)
            tk.Label(sd, text=d, bg=self.CONTENT_BG, fg="#7F8C8D", font=('Segoe UI', 9)).pack(anchor="w", padx=38, pady=(0, 5))

        self.fp_vars = {}; sf = self.create_scroll_area(t2)
        for c, i, n, d in FLATPAK_SOFTWARE:
            v = tk.BooleanVar(); self.fp_vars[c] = v
            ttk.Checkbutton(sf, text=f"{i}  {n}", variable=v, style='App.TCheckbutton').pack(anchor="w", pady=(10, 0), padx=10)
            tk.Label(sf, text=d, bg=self.CONTENT_BG, fg="#7F8C8D", font=('Segoe UI', 9)).pack(anchor="w", padx=38, pady=(0, 5))

        self.de_vars = {}; sde = self.create_scroll_area(t3)
        for n, cfg in DE_COMMANDS.items():
            dc = tk.Frame(sde, bg=self.CONTENT_BG); dc.pack(fill="x", pady=5, padx=10)
            tk.Label(dc, text=f"🖥️ {n}", font=('Segoe UI', 11, 'bold'), bg=self.CONTENT_BG, fg="#2C3E50").pack(anchor="w")
            v = tk.StringVar(value="none"); self.de_vars[n] = v
            of = tk.Frame(dc, bg=self.CONTENT_BG); of.pack(anchor="w", padx=25, pady=0)
            for txt, val in [("None", "none"), ("Full", "full"), ("Minimal", "minimal"), ("Core", "core"), ("Remove", "remove")]: ttk.Radiobutton(of, text=txt, variable=v, value=val).pack(side="left", padx=5)

        self.wm_vars = {}; swm = self.create_scroll_area(t4)
        for n, cfg in WM_COMMANDS.items():
            wc = tk.Frame(swm, bg=self.CONTENT_BG); wc.pack(fill="x", pady=5, padx=10)
            tk.Label(wc, text=f"🪟 {n.upper()}", font=('Segoe UI', 11, 'bold'), bg=self.CONTENT_BG, fg="#2C3E50").pack(anchor="w")
            v = tk.StringVar(value="none"); self.wm_vars[n] = v
            of = tk.Frame(wc, bg=self.CONTENT_BG); of.pack(anchor="w", padx=25, pady=0)
            for txt, val in [("None", "none"), ("Install", "install"), ("Remove", "remove")]: ttk.Radiobutton(of, text=txt, variable=v, value=val).pack(side="left", padx=5)

        ttk.Button(f, text="Apply Changes", style='Action.TButton', command=self.install_sw).pack(anchor="w", pady=10)

    def install_sw(self):
        cmds = ["cd /tmp || exit", "apt-get update"]
        debs = [c for c, v in self.deb_vars.items() if v.get() and c not in ["docker", "chrome", "edge", "brave", "firefox", "opera", "operagx", "onlyoffice"]]
        if debs: cmds.append(f"apt-get install -y {' '.join(debs)}")
        
        for c, v in self.deb_vars.items():
            if v.get() and c == "docker": cmds.extend(["apt-get remove -y docker.io docker-doc docker-compose podman-docker containerd runc", "apt-get update", "apt-get install -y ca-certificates curl gnupg", "install -m 0755 -d /etc/apt/keyrings", "curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg --yes", "echo \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian $(. /etc/os-release && echo \\\"$VERSION_CODENAME\\\") stable\" | tee /etc/apt/sources.list.d/docker.list > /dev/null", "apt-get update", "apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin"])
            elif v.get() and c == "chrome": cmds.extend(["wget -qO /tmp/chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb", "dpkg -i /tmp/chrome.deb", "apt-get -f install -y"])
            elif v.get() and c == "edge": cmds.extend(["apt-get install -y ca-certificates curl gnupg", "curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > /etc/apt/keyrings/microsoft.gpg", "chmod a+r /etc/apt/keyrings/microsoft.gpg", "echo 'deb [arch=amd64 signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/edge stable main' > /etc/apt/sources.list.d/microsoft-edge.list", "apt-get update", "apt-get install -y microsoft-edge-stable"])
            elif v.get() and c == "brave": cmds.append("curl -fsS https://dl.brave.com/install.sh | sh")
            elif v.get() and c == "firefox": cmds.extend(["install -d -m 0755 /etc/apt/keyrings", "wget -q https://packages.mozilla.org/apt/repo-signing-key.gpg -O- | tee /etc/apt/keyrings/packages.mozilla.org.asc > /dev/null", "echo 'deb [signed-by=/etc/apt/keyrings/packages.mozilla.org.asc] https://packages.mozilla.org/apt mozilla main' > /etc/apt/sources.list.d/mozilla.list", "apt-get update", "apt-get install -y firefox"])
            elif v.get() and c == "opera": cmds.extend(["wget -qO- https://deb.opera.com/archive.key | gpg --dearmor | dd of=/usr/share/keyrings/opera-browser.gpg", "echo 'deb [signed-by=/usr/share/keyrings/opera-browser.gpg] https://deb.opera.com/opera-stable/ stable non-free' > /etc/apt/sources.list.d/opera-archive.list", "apt-get update", "apt-get install -y opera-stable"])
            elif v.get() and c == "operagx": cmds.extend(["wget -qO- https://deb.opera.com/archive.key | gpg --dearmor | dd of=/usr/share/keyrings/opera-browser.gpg", "echo 'deb [signed-by=/usr/share/keyrings/opera-browser.gpg] https://deb.opera.com/opera-gx-stable/ stable non-free' > /etc/apt/sources.list.d/opera-archive.list", "apt-get update", "apt-get install -y opera-gx-stable"])
            elif v.get() and c == "onlyoffice": cmds.extend(["mkdir -p -m 700 ~/.gnupg", "gpg --no-default-keyring --keyring gnupg-ring:/tmp/onlyoffice.gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys CB2DE8E5", "chmod 644 /tmp/onlyoffice.gpg", "chown root:root /tmp/onlyoffice.gpg", "mv /tmp/onlyoffice.gpg /usr/share/keyrings/onlyoffice.gpg", "echo 'deb [signed-by=/usr/share/keyrings/onlyoffice.gpg] https://download.onlyoffice.com/repo/debian squeeze main' > /etc/apt/sources.list.d/onlyoffice.list", "apt-get update", "apt-get install -y onlyoffice-desktopeditors"])

        fpaks = [c for c, v in self.fp_vars.items() if v.get()]
        if fpaks: cmds.extend(["apt-get install -y flatpak", "flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo", f"flatpak install -y flathub {' '.join(fpaks)}"])

        de_act = False
        for n, v in self.de_vars.items():
            act = v.get()
            if act in ["full", "minimal", "core"]: cmds.extend([f"apt-get install -y {DE_COMMANDS[n][act]}", "systemctl set-default graphical.target"]); de_act = True
            elif act == "remove": cmds.extend([f"dpkg -l | awk '/^ii/ && ($2 ~ /{DE_COMMANDS[n]['rm_regex']}/){{print $2}}' | xargs -r apt-get purge -y", "apt-get autoremove -y"]); de_act = True

        for n, v in self.wm_vars.items():
            act = v.get()
            if act == "install":
                cmds.extend([WM_COMMANDS[n]["install"], "mkdir -p ~/.config", "apt-get install -y papirus-icon-theme", "update-alternatives --set x-cursor-theme /usr/share/icons/Papirus || true"])
                de_act = True
            elif act == "remove": cmds.extend([f"dpkg -l | awk '/^ii/ && ($2 ~ /{WM_COMMANDS[n]['rm_regex']}/){{print $2}}' | xargs -r apt-get purge -y", "apt-get autoremove -y"]); de_act = True

        if len(cmds) > 2 or de_act: self.execute_in_terminal(cmds)
        else: messagebox.showinfo("Info", "No actions selected.")

    def setup_uninstall_sw_page(self):
        f = ttk.Frame(self.content_area); self.pages["uninstall_sw"] = f
        ttk.Label(f, text="Uninstall System Software", style='Header.TLabel').pack(anchor="w", pady=(0, 10))
        self.scroll_u_frame = self.create_scroll_area(f); self.u_vars = {}
        bf = tk.Frame(f, bg=self.CONTENT_BG); bf.pack(anchor="w", pady=10)
        self.btn_ref_sw = ttk.Button(bf, text="Refresh Installed List", command=self.refresh_software_list); self.btn_ref_sw.pack(side="left", padx=5)
        self.btn_un_sw = ttk.Button(bf, text="Uninstall Selected", style='Danger.TButton', command=self.uninstall_software); self.btn_un_sw.pack(side="left")

    def fetch_software_list(self):
        try:
            res = subprocess.run("find /usr/share/applications ~/.local/share/applications /var/lib/flatpak/app -name '*.desktop' -exec grep -H '^Exec=' {} \\; | awk -F'=' '{print $2}' | awk '{print $1}' | rev | cut -d'/' -f1 | rev | sort -u", shell=True, capture_output=True, text=True).stdout.strip().split('\n')
            pkgs = set()
            for b in res:
                if b and not b.startswith("%"):
                    if b.startswith("com.") or b.startswith("org."): pkgs.add(f"flatpak:{b}")
                    else:
                        p = subprocess.run(f"dpkg -S $(which {b} 2>/dev/null) 2>/dev/null | cut -d':' -f1", shell=True, capture_output=True, text=True).stdout.strip()
                        if p: pkgs.update(p.split('\n'))
            bl = ["coreutils", "dpkg", "apt", "bash", "systemd", "dbus"]
            self.root.after(0, self.update_sw_cb, sorted([p for p in pkgs if p not in bl]))
        except: self.root.after(0, self.update_sw_cb, [])

    def update_sw_cb(self, pkgs):
        for w in self.scroll_u_frame.winfo_children(): w.destroy()
        self.u_vars.clear()
        if not pkgs: tk.Label(self.scroll_u_frame, text="No removable GUI apps found.", bg=self.CONTENT_BG).pack(anchor="w", pady=10, padx=10)
        else:
            for p in pkgs:
                v = tk.BooleanVar(); self.u_vars[p] = v
                ttk.Checkbutton(self.scroll_u_frame, text=f"🗑️ {p}", variable=v).pack(anchor="w", pady=2, padx=10)
        self.btn_un_sw.config(state="normal"); self.btn_ref_sw.config(state="normal")

    def refresh_software_list(self):
        for w in self.scroll_u_frame.winfo_children(): w.destroy()
        tk.Label(self.scroll_u_frame, text="Scanning installed software... Please wait.", bg=self.CONTENT_BG, font=('Segoe UI', 10, 'italic')).pack(anchor="w", pady=10, padx=10)
        self.btn_un_sw.config(state="disabled"); self.btn_ref_sw.config(state="disabled")
        threading.Thread(target=self.fetch_software_list, daemon=True).start()

    def uninstall_software(self):
        rem = [p for p, v in self.u_vars.items() if v.get()]
        if not rem: return messagebox.showinfo("Info", "No software selected for removal.")
        if messagebox.askyesno("Confirm", f"Remove {len(rem)} packages?"):
            cmds = ["cd /tmp || exit"]
            for p in rem:
                if p.startswith("flatpak:"): cmds.append(f"flatpak uninstall -y {p.split(':')[1]}")
                else: cmds.append(f"apt-get purge -y {p}")
            cmds.extend(["apt-get autoremove -y", "apt-get clean"])
            self.execute_in_terminal(cmds); self.refresh_software_list()

    def setup_drivers_page(self):
        f = ttk.Frame(self.content_area); self.pages["drivers"] = f
        ttk.Label(f, text="Drivers & Hardware", style='Header.TLabel').pack(anchor="w", pady=(0, 10))
        inf = tk.Frame(f, bg="#FFF", bd=1, relief="solid", padx=10, pady=10); inf.pack(fill='x', pady=10)
        try:
            g = subprocess.run("lspci | grep -iE 'vga|3d|display'", shell=True, capture_output=True, text=True).stdout.strip()
            n = subprocess.run("lspci | grep -iE 'network|ethernet|wireless'", shell=True, capture_output=True, text=True).stdout.strip()
            s = subprocess.run("lspci | grep -i audio", shell=True, capture_output=True, text=True).stdout.strip()
            b = subprocess.run("lsusb | grep -i bluetooth", shell=True, capture_output=True, text=True).stdout.strip()
            pci_info = f"GPU:\n{g}\n\nNetwork:\n{n}\n\nSound:\n{s}\n\nBluetooth:\n{b}"
        except: pci_info = "Command 'lspci' not found."
        tk.Label(inf, text="Detected Devices:", bg="#FFF", font=('Segoe UI', 10, 'bold')).pack(anchor='w')
        tk.Label(inf, text=pci_info, bg="#FFF", fg="#2980b9", justify="left").pack(anchor='w', pady=5)
        
        sa = self.create_scroll_area(f); self.drv_vars = {}
        opts = [
            ("nvidia", "Proprietary NVIDIA Driver (nvidia-driver, linux-headers)", "Proprietary"),
            ("broadcom", "Proprietary Broadcom Network Driver (broadcom-sta-dkms)", "Proprietary"),
            ("firmware", "Firmware Wireless Driver (Realtek, Intel Wi-Fi/BT, Atheros)", "Proprietary/Non-Free"),
            ("amd", "AMD Open Source Drivers (firmware-amd-graphics, libgl1-mesa-dri)", "Open Source"),
            ("intel", "Intel Arc / Integrated Open Source (mesa, va-driver)", "Open Source"),
            ("nouveau", "Nouveau Display Driver (NVIDIA Open Source)", "Open Source")
        ]
        for c, t, cat in opts:
            v = tk.BooleanVar(); self.drv_vars[c] = v
            ttk.Checkbutton(sa, text=f"[{cat}] {t}", variable=v).pack(anchor="w", pady=5)
        ttk.Button(f, text="Apply Drivers", style='Action.TButton', command=self.run_drv).pack(pady=10, anchor="w")

    def run_drv(self):
        sel = [c for c, v in self.drv_vars.items() if v.get()]
        if not sel: return messagebox.showinfo("Info", "No driver changes selected.")
        cmds = ["sed -i -e 's/ main$/ main contrib non-free non-free-firmware/' -e 's/ main contrib$/ main contrib non-free non-free-firmware/' /etc/apt/sources.list", "apt-get update"]
        if "nvidia" in sel: cmds.append("apt-get install -y nvidia-driver linux-headers-$(uname -r)")
        if "broadcom" in sel: cmds.append("apt-get install -y firmware-brcm80211 firmware-b43-installer firmware-b43legacy-installer broadcom-sta-dkms")
        if "firmware" in sel: cmds.append("apt-get install -y firmware-linux firmware-linux-nonfree firmware-iwlwifi firmware-realtek firmware-atheros firmware-misc-nonfree")
        if "amd" in sel: cmds.append("apt-get install -y firmware-amd-graphics libgl1-mesa-dri libglx-mesa0 mesa-vulkan-drivers xserver-xorg-video-amdgpu")
        if "intel" in sel: cmds.append("apt-get install -y mesa-utils libgl1-mesa-dri libglx-mesa0 mesa-vulkan-drivers intel-media-va-driver-non-free firmware-misc-nonfree")
        if "nouveau" in sel: cmds.extend(["apt-get purge -y nvidia-*", "apt-get install -y xserver-xorg-video-nouveau"])
        self.execute_in_terminal(cmds)

    def show_ip_addresses(self):
        try:
            loc = subprocess.run("ip -4 addr show | grep -v '127.0.0.1' | grep inet | awk '{print $2}'", shell=True, capture_output=True, text=True).stdout.strip()
            pub = subprocess.run("curl -s ifconfig.me", shell=True, capture_output=True, text=True).stdout.strip()
            messagebox.showinfo("IP Addresses", f"Local IP Address(es):\n{loc}\n\nPublic IP Address:\n{pub}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to retrieve IP addresses: {e}")

    def test_wifi(self):
        cmds = [
            "echo -e '\\e[1;34m[*] Installing Wi-Fi audit tools & dependencies...\\e[0m'",
            "apt-get update",
            "apt-get install -y network-manager wpasupplicant wireless-tools iw rfkill nmap tcpdump",
            "systemctl enable --now NetworkManager",
            "rfkill unblock wifi",
            "echo -e '\\e[1;32m[*] Wi-Fi tools active.\\e[0m'",
            "echo -e '\\e[1;34m[*] Available Wi-Fi Networks:\\e[0m'",
            "nmcli dev wifi list",
            "echo -e '\\n\\e[1;34m[*] Scanning local subnet for active hosts...\\e[0m'",
            "IFACE=$(ip route | grep default | grep -oP '(?<=dev )\\S+' | head -n1)",
            "if [ -n \"$IFACE\" ]; then",
            "  SUBNET=$(ip -4 addr show $IFACE | grep -oP '(?<=inet \\s)\\d+\\.\\d+\\.\\d+\\.0/24' || echo '')",
            "  if [ -n \"$SUBNET\" ]; then nmap -sn $SUBNET; else echo 'Subnet not found.'; fi",
            "else echo 'No active network interface found.'; fi"
        ]
        self.execute_in_terminal(cmds)

    def setup_rdp_server(self):
        cmds = [
            "echo -e '\\e[1;34m[*] Setting up Remote Desktop (RDP) Server...\\e[0m'",
            "apt-get update && apt-get install -y xfce4 xfce4-goodies xrdp ufw",
            "echo 'xfce4-session' > /etc/skel/.xsession",
            "systemctl enable xrdp && systemctl restart xrdp",
            "ufw allow 3389/tcp",
            "echo -e '\\n\\e[1;32m[+] RDP Server is Ready!\\e[0m'",
            "echo 'Use an RDP Client (like Remmina or Windows Remote Desktop) to connect to your IP on port 3389.'"
        ]
        self.execute_in_terminal(cmds)

    def setup_network_page(self):
        f = ttk.Frame(self.content_area); self.pages["network"] = f
        ttk.Label(f, text="Network Configuration", style='Header.TLabel').pack(anchor="w", pady=(0, 10))
        sa = self.create_scroll_area(f)
        
        inf = tk.LabelFrame(sa, text="Network Info & Diagnostics", bg=self.CONTENT_BG); inf.pack(fill="x", padx=10, pady=10)
        tk.Button(inf, text="Show Public & Local IP", command=self.show_ip_addresses).pack(side="left", padx=5, pady=10)
        tk.Button(inf, text="Speedtest (Terminal)", command=lambda: self.execute_in_terminal(["speedtest-cli"])).pack(side="left", padx=5)
        tk.Button(inf, text="Test Wi-Fi / Audit", command=self.test_wifi).pack(side="left", padx=5)

        mgr = tk.LabelFrame(sa, text="Connection Management", bg=self.CONTENT_BG); mgr.pack(fill="x", padx=10, pady=10)
        tk.Button(mgr, text="Open Network Manager (nmtui)", command=lambda: self.execute_in_terminal(["nmtui"])).pack(side="left", padx=5, pady=10)
        tk.Button(mgr, text="Show Saved Wi-Fi Passwords", command=lambda: self.execute_in_terminal(["cat /etc/NetworkManager/system-connections/* | grep -E '^id=|^psk='"])).pack(side="left", padx=5)
        tk.Button(mgr, text="Edit /etc/hosts", command=lambda: self.execute_in_terminal(["nano /etc/hosts"])).pack(side="left", padx=5)

        rdp = tk.LabelFrame(sa, text="Remote Desktop", bg=self.CONTENT_BG); rdp.pack(fill="x", padx=10, pady=10)
        tk.Button(rdp, text="Setup RDP Server (XFCE)", command=self.setup_rdp_server).pack(side="left", padx=5, pady=10)
        tk.Button(rdp, text="Install RDP Client (Remmina)", command=lambda: self.execute_in_terminal(["apt-get update", "apt-get install -y remmina remmina-plugin-rdp"])).pack(side="left", padx=5)

        mac = tk.LabelFrame(sa, text="MAC Address Changer (Spoofing)", bg=self.CONTENT_BG); mac.pack(fill="x", padx=10, pady=10)
        tk.Label(mac, text="Select Interface:", bg=self.CONTENT_BG).pack(side="left", padx=5)
        self.iface_var = tk.StringVar()
        self.mac_cb = ttk.Combobox(mac, textvariable=self.iface_var, state="readonly", width=15)
        self.mac_cb.pack(side="left", padx=5, pady=10)
        tk.Button(mac, text="Randomize MAC", command=lambda: self.execute_in_terminal([f"ip link set dev {self.iface_var.get()} down", f"macchanger -r {self.iface_var.get()}", f"ip link set dev {self.iface_var.get()} up"]) if self.iface_var.get() else None).pack(side="left", padx=5)
        tk.Button(mac, text="Restore Original MAC", command=lambda: self.execute_in_terminal([f"ip link set dev {self.iface_var.get()} down", f"macchanger -p {self.iface_var.get()}", f"ip link set dev {self.iface_var.get()} up"]) if self.iface_var.get() else None).pack(side="left", padx=5)
        self.refresh_interfaces()

    def refresh_interfaces(self):
        try: self.mac_cb['values'] = [i for i in os.listdir('/sys/class/net') if i != 'lo']
        except: pass

    def get_users(self):
        try: return subprocess.run("awk -F':' '{ if ($3 >= 1000 && $3 < 60000) print $1 }' /etc/passwd", shell=True, capture_output=True, text=True).stdout.strip().split('\n')
        except: return []

