        ttk.Button(af, text="Install & Switch DM", style='Danger.TButton', command=self.switch_dm).pack(side="left", padx=5)

    def apply_grub(self):
        to = self.g_to.get()
        if not to.isdigit(): return messagebox.showerror("Error", "Timeout must be a valid number.")
        cmds = [
            "cd /tmp || exit",
            "echo -e '\\e[1;34m[*] Applying GRUB Configurations...\\e[0m'",
            "cp /etc/default/grub /etc/default/grub.bak",
            f"sed -i 's/^GRUB_TIMEOUT=.*/GRUB_TIMEOUT={to}/' /etc/default/grub",
            "sed -i '/^GRUB_COLOR_NORMAL=/d' /etc/default/grub",
            "sed -i '/^GRUB_COLOR_HIGHLIGHT=/d' /etc/default/grub",
            f"echo 'GRUB_COLOR_NORMAL=\"{self.grub_color_normal.get()}\"' >> /etc/default/grub",
            f"echo 'GRUB_COLOR_HIGHLIGHT=\"{self.grub_color_highlight.get()}\"' >> /etc/default/grub"
        ]
        if self.g_hid.get(): cmds.extend(["sed -i 's/^GRUB_TIMEOUT_STYLE=.*/GRUB_TIMEOUT_STYLE=hidden/' /etc/default/grub", "grep -q '^GRUB_TIMEOUT_STYLE=' /etc/default/grub || echo 'GRUB_TIMEOUT_STYLE=hidden' >> /etc/default/grub"])
        else: cmds.extend(["sed -i 's/^GRUB_TIMEOUT_STYLE=.*/GRUB_TIMEOUT_STYLE=menu/' /etc/default/grub", "grep -q '^GRUB_TIMEOUT_STYLE=' /etc/default/grub || echo 'GRUB_TIMEOUT_STYLE=menu' >> /etc/default/grub"])
            
        if self.g_osp.get(): cmds.extend(["sed -i 's/^#GRUB_DISABLE_OS_PROBER=false/GRUB_DISABLE_OS_PROBER=false/' /etc/default/grub", "grep -q '^GRUB_DISABLE_OS_PROBER=false' /etc/default/grub || echo 'GRUB_DISABLE_OS_PROBER=false' >> /etc/default/grub"])
        else: cmds.extend(["sed -i 's/^GRUB_DISABLE_OS_PROBER=false/#GRUB_DISABLE_OS_PROBER=false/' /etc/default/grub"])
            
        bg = self.g_bg.get()
        if bg and os.path.exists(bg):
            ext = bg.split('.')[-1].lower()
            cmds.extend([f"cp \"{bg}\" /boot/grub/custom_bg.{ext}", "sed -i '/^GRUB_BACKGROUND=/d' /etc/default/grub", f"echo 'GRUB_BACKGROUND=\"/boot/grub/custom_bg.{ext}\"' >> /etc/default/grub"])
            
        cmds.append("update-grub")
        self.execute_in_terminal(cmds)

    def apply_plymouth(self):
        bg = self.plymouth_bg_path.get()
        if not bg or not os.path.exists(bg): return messagebox.showwarning("Warning", "Please select a valid PNG image for Plymouth.")
        theme = self.plymouth_theme_name.get().replace(" ", "-").lower() or "my-theme"
        cmds = [
            "echo -e '\\e[1;34m[*] Installing Plymouth and configuring custom theme...\\e[0m'",
            "apt-get update && apt-get install -y plymouth plymouth-themes",
            "THEME_BASE='/usr/share/plymouth/themes'",
            "SOURCE_THEME='bgrt'",
            "[ ! -d \"$THEME_BASE/$SOURCE_THEME\" ] && SOURCE_THEME=$(ls $THEME_BASE | grep -v 'my-theme' | head -n1)",
            f"DST_DIR=\"$THEME_BASE/{theme}\"",
            "rm -rf \"$DST_DIR\"",
            "cp -a \"$THEME_BASE/$SOURCE_THEME\" \"$DST_DIR\"",
            "OLD_IMG=$(find \"$DST_DIR\" -maxdepth 1 -type f -iname '*.png' | head -n1)",
            f"[ -n \"$OLD_IMG\" ] && cp \"{bg}\" \"$OLD_IMG\" && chmod 644 \"$OLD_IMG\"",
            "PLY_FILE=$(find \"$DST_DIR\" -maxdepth 1 -type f -iname '*.plymouth' | head -n1)",
            f"sed -i 's/^Name=.*/Name={theme}/I' \"$PLY_FILE\"",
            "sed -i \"s|ImageDir=.*|ImageDir=$DST_DIR|\" \"$PLY_FILE\"",
            "update-alternatives --install /usr/share/plymouth/themes/default.plymouth default.plymouth \"$PLY_FILE\" 200",
            "update-alternatives --set default.plymouth \"$PLY_FILE\"",
            "update-initramfs -u"
        ]
        self.execute_in_terminal(cmds)

    def switch_dm(self):
        dm = self.dm_target_var.get()
        if not dm: return messagebox.showwarning("Warning", "Please select a Target Display Manager.")
        
        pkg_map = {"GDM3": "gdm3", "LightDM GTK": "lightdm lightdm-gtk-greeter", "Slick-Greeter": "lightdm slick-greeter", "SDDM": "sddm"}
        dm_pkg = pkg_map.get(dm)
        dm_service = dm_pkg.split()[0]
        
        confirm = messagebox.askyesno("Confirm Installation", f"This will install {dm_pkg} and set it as default. You will need to reboot afterwards. Continue?")
        if confirm:
            cmds = [
                f"echo -e '\\e[1;34m[*] Installing and Switching to {dm}...\\e[0m'",
                "apt-get update",
                f"apt-get install -y {dm_pkg}",
                f"echo \"{dm_service} shared/default-x-display-manager select {dm_service}\" | debconf-set-selections",
                f"dpkg-reconfigure -f noninteractive {dm_service}",
                "systemctl disable gdm3 lightdm sddm lxdm || true",
                f"systemctl enable {dm_service} --now || true",
                "echo -e '\\e[1;32m[*] Display Manager updated. Please Reboot.\\e[0m'"
            ]
            self.execute_in_terminal(cmds)

    def apply_dm(self):
        dm = self.dm_target_var.get()
        if not dm: return messagebox.showwarning("Warning", "Please select a Target Display Manager.")
        bg = self.dm_bg.get()
        gtk = self.dm_gtk.get()
        icon = self.dm_ico.get()
        font = self.dm_fnt.get()
        user = self.au_var.get()
        autologin = self.en_au.get()
        show_users = str(self.shw_usr.get()).lower()
        
        cmds = [f"echo -e '\\e[1;34m[*] Applying Settings for {dm}...\\e[0m'"]
        
        if dm == "GDM3":
            if bg:
                cmds.extend([
                    "mkdir -p /etc/dconf/db/gdm.d",
                    f"echo -e '[org/gnome/desktop/background]\\npicture-uri=\\'file://{bg}\\'\\npicture-uri-dark=\\'file://{bg}\\'' > /etc/dconf/db/gdm.d/01-background",
                    "dconf update || true"
                ])
            if autologin and user:
                cmds.extend([
                    "sed -i '/^AutomaticLoginEnable=/d' /etc/gdm3/daemon.conf",
                    "sed -i '/^AutomaticLogin=/d' /etc/gdm3/daemon.conf",
                    f"sed -i '/\\[daemon\\]/a AutomaticLoginEnable=True\\nAutomaticLogin={user}' /etc/gdm3/daemon.conf"
                ])
            else:
                cmds.extend(["sed -i 's/^AutomaticLoginEnable=True/AutomaticLoginEnable=False/' /etc/gdm3/daemon.conf"])

        elif dm in ["LightDM GTK", "Slick-Greeter"]:
            conf = '/etc/lightdm/lightdm-gtk-greeter.conf' if dm == "LightDM GTK" else '/etc/lightdm/slick-greeter.conf'
            section = '[greeter]' if dm == "LightDM GTK" else '[Greeter]'
            cmds.extend([
                f"conf='{conf}'",
                "mkdir -p /etc/lightdm",
                "touch \"$conf\"",
                "cp -n \"$conf\" \"$conf.bak\" || true",
                f"awk -v bg='{bg}' -v theme='{gtk}' -v icon='{icon}' -v font='{font}' '"
                f"BEGIN {{found=0}} /^{section.replace('[','\\[').replace(']', '\\]')}/ {{found=1; print; next}} found==1 && /^(background|theme-name|icon-theme-name|font-name)=/ {{next}} {{print}} END {{if(found==0) print \"{section}\"; if(bg!=\"\") print \"background=\"bg; print \"theme-name=\"theme; print \"icon-theme-name=\"icon; print \"font-name=\"font}}' \"$conf\" > \"$conf.tmp\" && mv \"$conf.tmp\" \"$conf\""
            ])
            
            # Lightdm config for Autologin and Hide users
            hide_users = "true" if show_users == "false" else "false"
            cmds.extend([
                "l_conf='/etc/lightdm/lightdm.conf'",
                "touch \"$l_conf\"",
                f"sed -i '/^greeter-hide-users=/d' \"$l_conf\"",
                f"sed -i '/\\[Seat:\\*\\]/a greeter-hide-users={hide_users}' \"$l_conf\""
            ])
            
            if autologin and user:
                cmds.extend([
                    f"sed -i '/^autologin-user=/d' \"$l_conf\"",
                    f"sed -i '/^autologin-user-timeout=/d' \"$l_conf\"",
                    f"sed -i '/\\[Seat:\\*\\]/a autologin-user={user}\\nautologin-user-timeout=0' \"$l_conf\""
                ])
            else:
                cmds.extend([f"sed -i '/^autologin-user=/d' \"$l_conf\""])

        elif dm == "SDDM":
            cmds.extend([
                "sddm_conf='/etc/sddm.conf'",
                "[ -f /etc/sddm.conf.d/kde_settings.conf ] && sddm_conf='/etc/sddm.conf.d/kde_settings.conf'",
                "mkdir -p $(dirname \"$sddm_conf\")",
                "touch \"$sddm_conf\"",
                "cp -n \"$sddm_conf\" \"$sddm_conf.bak\" || true",
                "awk -v theme='breeze' 'BEGIN{found=0} /^\\[Theme\\]/{found=1; print; next} found==1 && /^Current=/{next} {print} END{if(found==0) print \"[Theme]\"; print \"Current=\"theme}' \"$sddm_conf\" > \"$sddm_conf.tmp\" && mv \"$sddm_conf.tmp\" \"$sddm_conf\""
            ])
            if bg:
                cmds.append(f"[ -f '/usr/share/sddm/themes/breeze/theme.conf' ] && awk -v bg='{bg}' 'BEGIN{{found=0}} /^background=/{{found=1; print \"background=\"bg; next}} {{print}} END{{if(found==0) print \"background=\"bg}}' /usr/share/sddm/themes/breeze/theme.conf > /usr/share/sddm/themes/breeze/theme.conf.tmp && mv /usr/share/sddm/themes/breeze/theme.conf.tmp /usr/share/sddm/themes/breeze/theme.conf")
            
            # SDDM Autologin and Hide Users
            hide_users = "true" if show_users == "false" else "false"
            if autologin and user:
                cmds.extend([
                    "awk -v user='" + user + "' 'BEGIN{found=0} /^\\[Autologin\\]/{found=1; print; next} found==1 && /^(User|Session)=/{next} {print} END{if(found==0) print \"[Autologin]\"; print \"User=\"user; print \"Session=plasma\"}' \"$sddm_conf\" > \"$sddm_conf.tmp\" && mv \"$sddm_conf.tmp\" \"$sddm_conf\""
                ])
            else:
                cmds.extend(["sed -i '/^User=/d' \"$sddm_conf\""])
                
            cmds.extend([
                "awk -v hide='" + hide_users + "' 'BEGIN{found=0} /^\\[Users\\]/{found=1; print; next} found==1 && /^HideUsers=/{next} {print} END{if(found==0) print \"[Users]\"; if(hide==\"true\") print \"HideUsers=*\"}' \"$sddm_conf\" > \"$sddm_conf.tmp\" && mv \"$sddm_conf.tmp\" \"$sddm_conf\""
            ])

        cmds.append("echo -e '\\e[1;32m[*] Done. Restart your display manager or reboot to see changes.\\e[0m'")
        self.execute_in_terminal(cmds)

    def setup_sources_page(self):
        f = ttk.Frame(self.content_area); self.pages["sources"] = f
        
        ttk.Label(f, text="Edit APT Sources.list & Upgrade", style='Header.TLabel').pack(anchor="w", pady=(0, 10))
        ttk.Label(f, text="Modify your APT sources list below. Useful for upgrading OS version (e.g., bookworm to trixie).", wraplength=600).pack(anchor="w", pady=5)
        
        ff = tk.Frame(f, bg=self.CONTENT_BG); ff.pack(anchor="w", fill="x", pady=5)
        tk.Label(ff, text="Target File:", font=('Segoe UI', 10, 'bold'), bg=self.CONTENT_BG).pack(side="left", padx=(0, 10))
        
        self.src_var = tk.StringVar(value="/etc/apt/sources.list.d/debian.sources")
        files = ["/etc/apt/sources.list.d/debian.sources", "/etc/apt/sources.list", "/etc/apt/sources.list.d/sources.list", "/etc/apt/sources.list.d/official-package-repositories.list"]
        self.sources_dropdown = ttk.Combobox(ff, textvariable=self.src_var, values=files, width=50)
        self.sources_dropdown.pack(side="left", padx=5)
        ttk.Button(ff, text="Load File", command=self.load_sources_list).pack(side="left", padx=5)

        self.src_txt = tk.Text(f, height=15, width=80, font=('Consolas', 10), bd=1, relief="solid", bg="#FFFFFF")
        self.src_txt.pack(anchor="w", pady=10, fill="both", expand=True)
        
        bf = tk.Frame(f, bg=self.CONTENT_BG); bf.pack(anchor="w", pady=10)
        
        ttk.Button(bf, text="Save File", style='Action.TButton', command=self.save_sources).pack(side="left", padx=(0, 15))
        ttk.Button(bf, text="Update Sources (apt update)", command=lambda: self.execute_in_terminal(["apt-get update"], pause=False)).pack(side="left", padx=(0, 15))
        ttk.Button(bf, text="Run System Upgrade (dist-upgrade)", style='Danger.TButton', command=self.run_os_upgrade).pack(side="left")

    def load_sources_list(self):
        path = self.src_var.get()
        self.src_txt.delete("1.0", tk.END)
        if os.path.exists(path):
            try:
                with open(path, "r") as f: content = f.read()
                self.src_txt.insert(tk.END, content)
            except Exception as e: self.src_txt.insert(tk.END, f"# Error loading {path}: {e}")
        else:
            self.src_txt.insert(tk.END, f"# File {path} does not exist yet.\n# You can add sources here and save to create it.")

    def save_sources(self):
        path = self.src_var.get()
        content = self.src_txt.get("1.0", tk.END)
        try:
            with open("/tmp/sources_temp.list", "w") as f: f.write(content)
            cmds = [
                f"echo -e '\\e[1;34m[*] Backing up and saving {path}...\\e[0m'",
                f"[ -f \"{path}\" ] && cp \"{path}\" \"{path}.bak\"",
                f"mkdir -p $(dirname \"{path}\")",
                f"cp /tmp/sources_temp.list \"{path}\""
            ]
            self.execute_in_terminal(cmds, pause=False)
            messagebox.showinfo("Success", f"File saved successfully to {path}. You can now click 'Update Sources'.")
        except Exception as e: messagebox.showerror("Error", f"Failed to prepare file: {e}")

    def run_os_upgrade(self):
        confirm = messagebox.askyesno("Confirm Upgrade", "Are you sure you want to run a full system upgrade?\nThis will run 'apt-get update && apt-get dist-upgrade -y'.\nEnsure your sources.list is correctly configured.")
        if confirm:
            cmds = [
                "echo -e '\\e[1;34m[*] Starting Full System Upgrade...\\e[0m'",
                "apt-get update",
                "apt-get dist-upgrade -y",
                "apt-get autoremove -y",
                "echo -e '\\e[1;32m[*] Upgrade process completed. A system reboot is highly recommended.\\e[0m'"
            ]
            self.execute_in_terminal(cmds)

